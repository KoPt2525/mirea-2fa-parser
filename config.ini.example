[mirea]
; Центральный mail.ru ящик — все пересылки сюда
central_email    = central@mail.ru
central_password = app_password_от_mail.ru

; JSON-ключ сервис-аккаунта Google (путь на сервере)
json_key = /home/user/.config/mirea-parser/key.json

; ID Google Таблицы (из URL между /d/ и /edit)
spreadsheet_id = ВАШ_ID_ТАБЛИЦЫ

; Опциональные настройки (менять не нужно)
sender    = sso@mirea.ru
imap_host = imap.mail.ru
imap_port = 993
